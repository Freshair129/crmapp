# =============================================================================
# V School CRM v2 — Environment Variables Template
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ห้าม commit .env ขึ้น git เด็ดขาด
# =============================================================================

# -----------------------------------------------------------------------------
# Facebook / Meta API
# https://developers.facebook.com/apps/
# -----------------------------------------------------------------------------
FB_APP_ID=your_app_id_here
FB_ACCESS_TOKEN=your_long_lived_page_access_token   # ~3 months, ต่ออายุก่อนหมด
FB_AD_ACCOUNT_ID=act_XXXXXXXXX
FB_PAGE_ID=XXXXXXXXXXXXXXXXX
FB_PAGE_ACCESS_TOKEN=your_page_access_token

# Webhook verify token (กำหนดเองได้ — ต้องตรงกับที่ตั้งใน Meta Developer Console)
FB_VERIFY_TOKEN=your_random_verify_token_string
FB_APP_SECRET=your_facebook_app_secret_here     # ใช้สำหรับ signature validation

...

# -----------------------------------------------------------------------------
# NextAuth.js
# NEXTAUTH_SECRET: สร้างด้วย  openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Security & Schedulers
# -----------------------------------------------------------------------------
CRON_SECRET=your_random_cron_secret_here      # x-cron-secret header for /api/marketing/sync

# -----------------------------------------------------------------------------
# App Config
# -----------------------------------------------------------------------------
CRM_BASE_URL=http://localhost:3000
DISABLE_LOCAL_CACHE=false    # true = บังคับ fetch ใหม่ทุกครั้ง (debug)

# -----------------------------------------------------------------------------
# Upstash (Service-less Infrastructure)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-database-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=your_qstash_current_signing_key
QSTASH_NEXT_SIGNING_KEY=your_qstash_next_signing_key

NEXT_PUBLIC_APP_URL=http://localhost:3000

