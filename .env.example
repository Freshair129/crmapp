# =============================================================================
# V School CRM v2 — Environment Variables Template
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ห้าม commit .env ขึ้น git เด็ดขาด
# =============================================================================

# -----------------------------------------------------------------------------
# Facebook / Meta API
# https://developers.facebook.com/apps/
# -----------------------------------------------------------------------------
FB_APP_ID=your_app_id_here
FB_ACCESS_TOKEN=your_long_lived_page_access_token   # ~3 months, ต่ออายุก่อนหมด
FB_AD_ACCOUNT_ID=act_XXXXXXXXX
FB_PAGE_ID=XXXXXXXXXXXXXXXXX
FB_PAGE_ACCESS_TOKEN=your_page_access_token

# Webhook verify token (กำหนดเองได้ — ต้องตรงกับที่ตั้งใน Meta Developer Console)
FB_VERIFY_TOKEN=your_random_verify_token_string

# -----------------------------------------------------------------------------
# Google Gemini AI
# https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key

# -----------------------------------------------------------------------------
# LINE Messaging API
# https://developers.line.biz/console/
# -----------------------------------------------------------------------------
LINE_CHANNEL_ID=your_channel_id
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_access_token
LINE_GROUP_ID=your_line_group_id           # Group สำหรับรับ alert
LINE_GROUP_MARKETING=your_marketing_group_id

# -----------------------------------------------------------------------------
# Slip Verification (SlipOK)
# https://slipok.com/
# -----------------------------------------------------------------------------
SLIPOK_API_KEY=your_slipok_api_key
SLIPOK_BRANCH_ID=your_branch_id

# -----------------------------------------------------------------------------
# Database (Local Docker Development)
# docker compose up -d  →  PostgreSQL บน port 5433
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/vschool_crm
DB_ADAPTER=pg

# Production (Supabase):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# -----------------------------------------------------------------------------
# NextAuth.js
# NEXTAUTH_SECRET: สร้างด้วย  openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# Production:
# NEXTAUTH_URL=https://crm.vschool.co.th

# -----------------------------------------------------------------------------
# App Config
# -----------------------------------------------------------------------------
CRM_BASE_URL=http://localhost:3000
DISABLE_LOCAL_CACHE=false    # true = บังคับ fetch ใหม่ทุกครั้ง (debug)

# Redis (ถ้าใช้ Redis Cloud แทน local Docker)
# REDIS_URL=redis://localhost:6379
