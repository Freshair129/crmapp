generator client {
  provider   = "prisma-client-js"
  engineType = "library"
  output     = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// DOMAIN: Customer
// ─────────────────────────────────────────────

model Customer {
  id             String          @id @default(uuid())
  customerId     String          @unique @map("customer_id")
  memberId       String?         @map("member_id")
  originId       String?         @map("origin_id") // ADR-025: source attribution (ad_id / qr_code_id) for ROAS
  status         String          @default("Active")
  firstName      String?         @map("first_name")
  lastName       String?         @map("last_name")
  nickName       String?         @map("nick_name")
  jobTitle       String?         @map("job_title")
  company        String?
  membershipTier String          @default("MEMBER") @map("membership_tier")
  lifecycleStage String          @default("Lead") @map("lifecycle_stage")
  joinDate       DateTime?       @map("join_date")
  profilePicture String?         @map("profile_picture")
  email          String?
  phonePrimary   String?         @map("phone_primary") // E.164 format after normalizePhone() — ADR-025
  lineId         String?         @map("line_id")
  facebookId     String?         @unique @map("facebook_id")
  facebookName   String?         @map("facebook_name")
  walletBalance  Float           @default(0) @map("wallet_balance")
  walletPoints   Int             @default(0) @map("wallet_points")
  walletCurrency String          @default("THB") @map("wallet_currency")
  intelligence   Json?           @default("{}")
  conversationId String?         @map("conversation_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  cart               CartItem[]
  conversations      Conversation[]
  inventory          InventoryItem[]
  orders             Order[]
  tasks              Task[]
  timeline           TimelineEvent[]
  enrollments        Enrollment[]
  packageEnrollments PackageEnrollment[]

  @@index([status])
  @@index([phonePrimary])
  @@index([firstName, lastName])
  @@map("customers")
}

model Order {
  id             String        @id @default(uuid())
  orderId        String        @unique @map("order_id")
  customerId     String        @map("customer_id")
  date           DateTime
  status         String        @default("PENDING")
  totalAmount    Float         @map("total_amount")
  paidAmount     Float         @default(0) @map("paid_amount")
  items          Json          @default("[]")
  closedById     String?       @map("closed_by_id")
  conversationId String?       @map("conversation_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  closedBy     Employee?     @relation("OrderCloser", fields: [closedById], references: [id])
  conversation Conversation? @relation("OrderConversation", fields: [conversationId], references: [id])
  transactions Transaction[]

  @@index([date])
  @@index([status])
  @@index([customerId])
  @@map("orders")
}

model Transaction {
  id            String   @id @default(uuid())
  transactionId String   @unique @map("transaction_id")
  orderId       String   @map("order_id")
  date          DateTime
  amount        Float
  type          String
  method        String   @default("Transfer")
  chatMessageId String?  @map("chat_message_id")
  note          String?
  slipImageUrl  String?  @map("slip_image_url")
  slipStatus    String?  @map("slip_status")
  slipData      Json?    @map("slip_data")
  createdAt     DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model InventoryItem {
  id         String    @id @default(uuid())
  customerId String    @map("customer_id")
  type       String
  itemId     String    @map("item_id")
  name       String
  enrollDate DateTime? @map("enroll_date")
  expiryDate DateTime? @map("expiry_date")
  status     String    @default("ACTIVE")
  metadata   Json?     @default("{}")
  createdAt  DateTime  @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("inventory_items")
}

model TimelineEvent {
  id         String   @id @default(uuid())
  eventId    String   @map("event_id")
  customerId String   @map("customer_id")
  date       DateTime
  type       String
  summary    String
  details    Json?    @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("timeline_events")
}

// ─────────────────────────────────────────────
// DOMAIN: Conversation
// ─────────────────────────────────────────────

model Conversation {
  id                 String    @id @default(uuid())
  conversationId     String    @unique @map("conversation_id")
  customerId         String?   @map("customer_id")
  channel            String    @default("facebook")
  participantName    String?   @map("participant_name")
  participantId      String?   @map("participant_id")
  assignedAgent      String?   @map("assigned_agent")
  status             String    @default("open") @map("status")  // open | pending | closed
  isStarred          Boolean   @default(false) @map("is_starred")
  lastMessageAt      DateTime? @map("last_message_at")
  unreadCount        Int       @default(0) @map("unread_count")
  assignedEmployeeId String?   @map("assigned_employee_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  assignedEmployee Employee?     @relation("ConversationAssignee", fields: [assignedEmployeeId], references: [id])
  customer         Customer?     @relation(fields: [customerId], references: [id])
  episodes         ChatEpisode[]
  messages         Message[]
  orders           Order[]       @relation("OrderConversation")

  @@index([status])
  @@index([channel])
  @@index([updatedAt])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  messageId      String   @unique @map("message_id")
  conversationId String   @map("conversation_id")
  fromName       String?  @map("from_name")
  fromId         String?  @map("from_id")
  content        String?
  hasAttachment  Boolean  @default(false) @map("has_attachment")
  attachmentType String?  @map("attachment_type")
  attachmentUrl  String?  @map("attachment_url")
  attachmentId   String?  @map("attachment_id")
  responderId    String?  @map("responder_id")
  metadata       Json?    @default("{}")
  episodeId      String?  @map("episode_id")
  sessionId      String?  @map("session_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  responder    Employee?    @relation("MessageResponder", fields: [responderId], references: [id])

  @@map("messages")
}

model ChatEpisode {
  id             String   @id @default(uuid())
  episodicId     String   @unique @map("episodic_id")
  episodicName   String   @map("episodic_name")
  msgRef         String?  @map("msg_ref")
  summary        String?
  salineAnchor   String?  @map("saline_anchor")
  state          String?
  note           String?
  cta            String?
  tags           Json?    @default("[]")
  sessionId      String   @map("session_id")
  conversationId String   @map("conversation_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("chat_episodes")
}

// ─────────────────────────────────────────────
// DOMAIN: Employee / RBAC
// ─────────────────────────────────────────────

model Employee {
  id           String    @id @default(uuid())
  employeeId   String    @unique @map("employee_id") // HR standard code, e.g. TVS-MKT-001
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  nickName     String?   @map("nick_name")
  email        String    @unique
  phone        String?
  department   String?
  passwordHash String    @map("password_hash")
  role         String    @default("AGENT") // ADR-026: Developer|Manager|Supervisor|Admin|Agent|Guest
  status       String    @default("ACTIVE")
  facebookSub  String?   @unique @map("facebook_sub") // Facebook App-Scoped User ID (ASID) จาก OAuth login
  identities   Json?     @default("{}") // { facebook: { psid, name }, line: { id } }
  settings     Json?     @default("{}")
  permissions  Json?     @default("[]") // granular overrides, e.g. ["edit_orders"]
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  assignedTasks         Task[]           @relation("AgentTasks")
  respondedMessages     Message[]        @relation("MessageResponder")
  assignedConversations Conversation[]   @relation("ConversationAssignee")
  closedOrders          Order[]          @relation("OrderCloser")
  soldEnrollments       Enrollment[]     @relation("EnrollmentSeller")
  instructedSchedules   CourseSchedule[] @relation("ScheduleInstructor")
  approvedRequests         PurchaseRequest[]  @relation("PRApprover")
  assignedAssets           Asset[]            @relation("AssetAssignee")
  packageEnrollmentsSold   PackageEnrollment[] @relation("PackageEnrollmentSeller")

  @@index([status])
  @@index([department])
  @@index([role])
  @@map("employees")
}

// ─────────────────────────────────────────────
// DOMAIN: Product / Cart
// ─────────────────────────────────────────────

model Product {
  id                  String     @id @default(uuid())
  productId           String     @unique @map("product_id")
  name                String
  description         String?
  price               Float
  basePrice           Float?     @map("base_price")
  image               String?
  category            String     @default("course")
  hours               Float?                                          // Phase 16: ชั่วโมงเรียนต่อคอร์ส
  days                Float?                                          // Phase 17: จำนวนวัน (0.5=ครึ่งวัน, 1=เต็มวัน, 2=2วัน)
  sessionType         String?    @map("session_type")                 // Phase 17: comma-sep "MORNING,AFTERNOON"
  instructorIds       String[]   @default([]) @map("instructor_ids") // Phase 17: employeeId[] ที่สอนคอร์สนี้ได้
  duration            Int?
  durationUnit        String?    @map("duration_unit")
  linkedMenuIds       String[]   @default([]) @map("linked_menu_ids") // id_standards: COURSE-TO-MENU link
  fallbackCategory    String?    @map("fallback_category")            // e.g. "JP", "TH"
  fallbackSubCategory String?    @map("fallback_sub_category")        // e.g. "H", "C"
  metadata            Json?      @default("{}")
  isActive            Boolean    @default(true) @map("is_active")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  cartItems                 CartItem[]
  enrollments               Enrollment[]
  enrollmentItems           EnrollmentItem[]
  schedules                 CourseSchedule[]
  courseMenus               CourseMenu[]
  courseEquipment           CourseEquipment[]
  packageCourses            PackageCourse[]
  packageEnrollmentCourses  PackageEnrollmentCourse[]

  @@index([category])
  @@index([isActive])
  @@map("products")
}

model CartItem {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  quantity   Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// DOMAIN: Marketing / Ads (ADR-024)
// ─────────────────────────────────────────────

model AdAccount {
  id        String    @id @default(uuid())
  accountId String    @unique @map("account_id")
  name      String
  currency  String    @default("THB")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  campaigns Campaign[]

  @@map("ad_accounts")
}

// ADR-024 D2: Campaign stores NO aggregated metrics — all figures computed Bottom-Up in app layer
// fb_* fields = Facebook API-reported snapshot, stored for audit only (compare vs. bottom-up)
model Campaign {
  id              String    @id @default(uuid())
  campaignId      String    @unique @map("campaign_id")
  name            String
  objective       String?
  status          String    @default("ACTIVE")
  isVisible       Boolean   @default(true) @map("is_visible")
  mappedProductId String?   @map("mapped_product_id")
  adAccountId     String?   @map("ad_account_id")
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  rawData         Json?     @map("raw_data")
  // Audit snapshot — values pulled directly from Facebook Campaign Insights API
  fbSpend         Float?    @map("fb_spend")
  fbClicks        Int?      @map("fb_clicks")
  fbLeads         Int?      @map("fb_leads")
  fbRevenue       Float?    @map("fb_revenue")
  fbSnapshotAt    DateTime? @map("fb_snapshot_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  adAccount AdAccount? @relation(fields: [adAccountId], references: [id])
  adSets    AdSet[]

  @@map("campaigns")
}

model AdSet {
  id          String   @id @default(uuid())
  adSetId     String   @unique @map("ad_set_id")
  name        String
  status      String
  campaignId  String   @map("campaign_id")
  dailyBudget Float?   @map("daily_budget")
  targeting   Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id])
  ads      Ad[]

  @@map("ad_sets")
}

model Ad {
  id             String   @id @default(uuid())
  adId           String   @unique @map("ad_id")
  name           String
  status         String
  deliveryStatus String?  @map("delivery_status")
  adSetId        String   @map("ad_set_id")
  creativeId     String?  @map("creative_id")
  experimentId   String?  @map("experiment_id")
  variantName    String?  @map("variant_name")
  spend          Float    @default(0)
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  cfr            Float    @default(0)
  revenue        Float    @default(0)
  roas           Float    @default(0)
  createdAt      DateTime @default(now()) @map("created_at") // used for creative fatigue detection (Phase 3)
  updatedAt      DateTime @updatedAt @map("updated_at")

  adSet        AdSet            @relation(fields: [adSetId], references: [id])
  creative     AdCreative?      @relation(fields: [creativeId], references: [id])
  experiment   Experiment?      @relation(fields: [experimentId], references: [id])
  dailyMetrics AdDailyMetric[]
  hourlyMetrics AdHourlyMetric[]
  hourlyLedger AdHourlyLedger[]
  liveStatus   AdLiveStatus?

  @@index([experimentId])
  @@map("ads")
}

model AdLiveStatus {
  id                 String   @id @default(uuid())
  adId               String   @unique @map("ad_id")
  lastImpressionTime DateTime @map("last_impression_time")
  isRunningNow       Boolean  @default(false) @map("is_running_now")
  updatedAt          DateTime @updatedAt @map("updated_at")

  ad Ad @relation(fields: [adId], references: [id])

  @@map("ad_live_status")
}

model AdCreative {
  id           String   @id @default(uuid())
  creativeId   String?  @unique @map("creative_id")
  name         String
  body         String?
  headline     String?
  imageUrl     String?  @map("image_url")
  videoUrl     String?  @map("video_url")
  callToAction String?  @map("call_to_action")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ads Ad[]

  @@map("ad_creatives")
}

model Experiment {
  id             String    @id @default(uuid())
  name           String
  description    String?
  status         String
  hypothesis     String?
  winningVariant String?   @map("winning_variant")
  conclusion     String?
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  ads Ad[]

  @@map("experiments")
}

model AdDailyMetric {
  id          String   @id @default(uuid())
  adId        String   @map("ad_id")
  date        DateTime @db.Date
  spend       Float
  impressions Int
  clicks      Int
  leads       Int
  purchases   Int
  revenue     Float    @default(0)
  roas        Float    @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  ad Ad @relation(fields: [adId], references: [adId])

  @@unique([adId, date])
  @@map("ad_daily_metrics")
}

model AdHourlyMetric {
  id          String   @id @default(uuid())
  adId        String   @map("ad_id")
  date        DateTime @db.Date
  hour        Int
  spend       Float
  impressions Int
  clicks      Int
  leads       Int
  purchases   Int
  revenue     Float    @default(0)
  roas        Float    @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  ad Ad @relation(fields: [adId], references: [adId])

  @@unique([adId, date, hour])
  @@map("ad_hourly_metrics")
}

// ADR-024 D4: Append-only hourly ledger for trend graphs. Never updated — only inserted.
// Delta rule: only write when delta != 0.
model AdHourlyLedger {
  id          String   @id @default(uuid())
  adId        String   @map("ad_id")
  date        DateTime @db.Date
  hour        Int
  spend       Float
  impressions Int
  clicks      Int
  leads       Int
  purchases   Int
  revenue     Float    @default(0)
  roas        Float    @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  ad Ad @relation(fields: [adId], references: [adId])

  @@index([adId, date, hour])
  @@map("ad_hourly_ledger")
}

// ─────────────────────────────────────────────
// DOMAIN: Tasks
// ─────────────────────────────────────────────

model Task {
  id          String    @id @default(uuid())
  taskId      String    @unique @map("task_id")
  customerId  String?   @map("customer_id")
  assigneeId  String?   @map("assignee_id")
  title       String
  description String?
  type        String    @default("FOLLOW_UP")
  priority    String    @default("MEDIUM")
  status      String    @default("PENDING")
  dueDate     DateTime? @map("due_date")
  completedAt DateTime? @map("completed_at")
  aiGenerated Boolean   @default(false) @map("ai_generated")
  aiContext   Json?     @map("ai_context")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  assignee Employee? @relation("AgentTasks", fields: [assigneeId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([status])
  @@index([dueDate])
  @@index([assigneeId])
  @@map("tasks")
}

// ─────────────────────────────────────────────
// DOMAIN: Audit
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  actor     String
  target    String?
  status    String   @default("PENDING")
  traceId   String?  @map("trace_id")
  details   Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([action, createdAt])
  @@index([target])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// DOMAIN: Notifications
// ─────────────────────────────────────────────

model NotificationRule {
  id          String   @id @default(uuid())
  ruleId      String   @unique @map("rule_id")     // NOT-[YYYYMMDD]-[SERIAL]
  name        String
  description String?
  event       String                               // MESSAGE_RECEIVED | CONVERSATION_CLOSED | INACTIVITY
  conditions  Json     @default("{}")              // { "vip": true, "keywords": ["..."] }
  actions     Json     @default("{}")              // { "lineNotify": "target_id", "email": "..." }
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("notification_rules")
}

// ─────────────────────────────────────────────
// DOMAIN: Course Enrollment + Kitchen Ops + Assets (Phase 15)
// ─────────────────────────────────────────────

model Enrollment {
  id           String           @id @default(uuid())
  enrollmentId String           @unique @map("enrollment_id")
  customerId   String           @map("customer_id")
  productId    String           @map("product_id")
  soldById     String?          @map("sold_by_id")
  totalPrice   Float            @map("total_price")
  status       String           @default("ACTIVE")
  enrolledAt   DateTime         @default(now()) @map("enrolled_at")
  notes        String?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  customer Customer         @relation(fields: [customerId], references: [id])
  product  Product          @relation(fields: [productId], references: [id])
  soldBy   Employee?        @relation("EnrollmentSeller", fields: [soldById], references: [id])
  items    EnrollmentItem[]

  @@index([status])
  @@index([customerId])
  @@index([enrolledAt])
  @@map("enrollments")
}

model EnrollmentItem {
  id             String            @id @default(uuid())
  enrollmentId   String            @map("enrollment_id")
  productId      String            @map("product_id")
  status         String            @default("PENDING")
  hoursCompleted Float             @default(0) @map("hours_completed")
  certLevel      Int?              @map("cert_level")
  completedAt    DateTime?         @map("completed_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  enrollment  Enrollment        @relation(fields: [enrollmentId], references: [id])
  product     Product           @relation(fields: [productId], references: [id])
  attendances ClassAttendance[]

  @@unique([enrollmentId, productId])
  @@index([status])
  @@index([enrollmentId])
  @@map("enrollment_items")
}

model CourseSchedule {
  id                String            @id @default(uuid())
  scheduleId        String            @unique @map("schedule_id")
  productId         String            @map("product_id")
  scheduledDate     DateTime          @map("scheduled_date")
  startTime         String?           @map("start_time")
  endTime           String?           @map("end_time")
  sessionType       String?           @map("session_type")    // Phase 16: MORNING|AFTERNOON|EVENING
  maxStudents       Int?              @map("max_students")
  confirmedStudents Int               @default(0) @map("confirmed_students")
  status            String            @default("OPEN")
  instructorId      String?           @map("instructor_id")
  classId           String?           @map("class_id")             // Phase 20: CLS-YYYYMM-XXX — cohort grouping multi-day schedules
  notes             String?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  product          Product           @relation(fields: [productId], references: [id])
  instructor       Employee?         @relation("ScheduleInstructor", fields: [instructorId], references: [id])
  attendances      ClassAttendance[]
  purchaseRequests PurchaseRequest[]

  @@index([scheduledDate])
  @@index([status])
  @@index([productId])
  @@index([classId])
  @@map("course_schedules")
}

model ClassAttendance {
  id               String         @id @default(uuid())
  enrollmentItemId String         @map("enrollment_item_id")
  scheduleId       String         @map("schedule_id")
  attendedAt       DateTime       @default(now()) @map("attended_at")
  hoursAttended    Float          @map("hours_attended")
  note             String?
  createdAt        DateTime       @default(now()) @map("created_at")

  enrollmentItem EnrollmentItem @relation(fields: [enrollmentItemId], references: [id])
  schedule       CourseSchedule @relation(fields: [scheduleId], references: [id])

  @@unique([enrollmentItemId, scheduleId])
  @@map("class_attendances")
}

model Ingredient {
  id           String                @id @default(uuid())
  ingredientId String                @unique @map("ingredient_id")
  name         String
  unit         String
  currentStock Float                 @default(0) @map("current_stock")
  minStock     Float                 @default(0) @map("min_stock")
  category     String                @default("OTHER")
  costPerUnit  Float?                @map("cost_per_unit")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  purchaseItems    PurchaseRequestItem[]
  recipeIngredients RecipeIngredient[]
  lots              IngredientLot[]

  @@index([category])
  @@index([name])
  @@map("ingredients")
}

model PurchaseRequest {
  id           String                @id @default(uuid())
  requestId    String                @unique @map("request_id")
  scheduleId   String?               @map("schedule_id")
  status       String                @default("DRAFT")
  approvedById String?               @map("approved_by_id")
  notes        String?
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  schedule   CourseSchedule?       @relation(fields: [scheduleId], references: [id])
  approvedBy Employee?             @relation("PRApprover", fields: [approvedById], references: [id])
  items      PurchaseRequestItem[]
  lots       IngredientLot[]

  @@index([status])
  @@index([createdAt])
  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id                String          @id @default(uuid())
  purchaseRequestId String          @map("purchase_request_id")
  ingredientId      String          @map("ingredient_id")
  qtyNeeded         Float           @map("qty_needed")
  qtyInStock        Float           @map("qty_in_stock")
  qtyToBuy          Float           @map("qty_to_buy")
  unit              String
  estimatedCost     Float?          @map("estimated_cost")

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id])
  ingredient      Ingredient      @relation(fields: [ingredientId], references: [id])

  @@unique([purchaseRequestId, ingredientId])
  @@map("purchase_request_items")
}

model Asset {
  id              String    @id @default(uuid())
  assetId         String    @unique @map("asset_id")
  name            String
  category        String    @default("GENERAL")
  status          String    @default("ACTIVE")
  location        String?
  assignedToId    String?   @map("assigned_to_id")
  purchaseDate    DateTime? @map("purchase_date")
  purchasePrice   Float?    @map("purchase_price")
  vendor          String?
  serialNumber    String?   @map("serial_number")
  warrantyExpiry  DateTime? @map("warranty_expiry")
  lastServiceDate DateTime? @map("last_service_date")
  notes           String?
  photos          Json      @default("[]") @map("photos") // Array of base64 or URL strings, max 5
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  assignedTo Employee? @relation("AssetAssignee", fields: [assignedToId], references: [id])

  @@index([category])
  @@index([status])
  @@map("assets")
}

// ─────────────────────────────────────────────
// DOMAIN: Recipe + Menu (Phase 16)
// ─────────────────────────────────────────────

model Recipe {
  id            String   @id @default(uuid())
  recipeId      String   @unique @map("recipe_id")     // RCP-[CHEF]-[CAT]-[SERIAL] e.g. RCP-AOI-JP-001
  name          String
  description   String?
  chef          String?                                // ตัวย่อเชฟ 3 ตัว เช่น AOI, FAH, BKK
  sellingPrice  Float?   @map("selling_price")         // ราคาขาย per menu (optional reference)
  estimatedCost Float?   @map("estimated_cost")        // ต้นทุนรวม (computed from RecipeIngredient or manual)
  category      String?                                // ประเภทอาหาร e.g. JP, TH, PASTRY
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  courseMenus CourseMenu[]
  ingredients RecipeIngredient[]
  equipment   RecipeEquipment[]

  @@index([category])
  @@index([isActive])
  @@map("recipes")
}

// Junction: Course (Product) ↔ Recipe (many-to-many)
// หนึ่งคอร์สมีได้หลาย recipe; หนึ่ง recipe ใช้ได้ในหลายคอร์ส
model CourseMenu {
  id          String  @id @default(uuid())
  productId   String  @map("product_id")
  recipeId    String  @map("recipe_id")
  dayNumber   Int     @default(1) @map("day_number")    // วันที่ (1, 2) ใน multi-day course
  sessionSlot String? @map("session_slot")              // MORNING|AFTERNOON|EVENING
  sortOrder   Int     @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  recipe  Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  // Phase 19: เพิ่ม dayNumber เข้า unique constraint — อนุญาตให้ใช้ recipe เดิมซ้ำใน Day1 + Day2 ของคอร์สเดียวกันได้
  @@unique([productId, recipeId, dayNumber])
  @@map("course_menus")
}

// อุปกรณ์ระดับคอร์ส (เช่น ผ้ากันเปื้อน) — แยกจาก RecipeEquipment ที่เป็นอุปกรณ์พิเศษต่อสูตร
model CourseEquipment {
  id            String  @id @default(uuid())
  productId     String  @map("product_id")
  name          String                                  // เช่น "ผ้ากันเปื้อน V School"
  qty           Int     @default(1)                    // จำนวนต่อนักเรียน 1 คน
  isIncluded    Boolean @default(true) @map("is_included")  // true = แถมฟรี, false = ต้องซื้อเพิ่ม
  estimatedCost Float?  @map("estimated_cost")
  notes         String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("course_equipment")
}

// วัตถุดิบที่ใช้ใน recipe (ตัดสต็อกจาก Ingredient)
model RecipeIngredient {
  id               String @id @default(uuid())
  recipeId         String @map("recipe_id")
  ingredientId     String @map("ingredient_id")
  qtyPerPerson     Float  @map("qty_per_person")      // ปริมาณต่อ 1 นักเรียน (หน่วยตาม unit field)
  unit             String                              // หน่วยที่ใช้ใน recipe (อาจต่างจาก Ingredient.unit)
  conversionFactor Float  @default(1) @map("conversion_factor") // Phase 19: conversion เทียบ Ingredient.unit, qty_deducted = qtyPerPerson × students × conversionFactor

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
  @@map("recipe_ingredients")
}

// อุปกรณ์พิเศษที่ต้องใช้ใน recipe (ไม่ใช่เครื่องครัวปกติ) — นับเป็น stock
// e.g. "แม่พิมพ์รูปดาวขนาด 10 นิ้ว", "ใบบัว 10cm"
model RecipeEquipment {
  id           String   @id @default(uuid())
  recipeId     String   @map("recipe_id")
  name         String                          // ชื่ออุปกรณ์
  unit         String   @default("piece")     // หน่วย
  qtyRequired  Int      @map("qty_required")  // จำนวนที่ต้องใช้ต่อ session
  currentStock Int      @default(0) @map("current_stock")
  minStock     Int      @default(0) @map("min_stock")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@map("recipe_equipment")
}

// ─────────────────────────────────────────────
// DOMAIN: Package (Phase 16)
// ─────────────────────────────────────────────

model Package {
  id            String   @id @default(uuid())
  packageId     String   @unique @map("package_id")    // PKG-[YYYY]-[SERIAL]
  name          String
  description   String?
  originalPrice Float    @map("original_price")        // ราคารวมก่อนลด (sum ของ course.price ทุกตัว)
  packagePrice  Float    @map("package_price")         // ราคาขายจริง (หลังลด)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  courses     PackageCourse[]
  gifts       PackageGift[]
  enrollments PackageEnrollment[]

  @@index([isActive])
  @@map("packages")
}

// คอร์สที่รวมอยู่ใน package
model PackageCourse {
  id           String  @id @default(uuid())
  packageId    String  @map("package_id")
  productId    String  @map("product_id")
  isRequired   Boolean @default(true) @map("is_required")   // ต้องเรียน (ไม่สามารถตัดออกได้)
  isLocked     Boolean @default(false) @map("is_locked")    // ห้าม swap แม้อยู่ใน swapGroup
  swapGroup    String? @map("swap_group")                   // ชื่อกลุ่ม swap เช่น "GROUP_A" (null = ไม่มีตัวเลือก)
  swapGroupMax Int?    @map("swap_group_max")               // เลือกได้สูงสุดกี่คอร์สจากกลุ่มนี้ (null = ทั้งหมด)
  sortOrder    Int     @default(0) @map("sort_order")

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([packageId, productId])
  @@map("package_courses")
}

// ของแถมหรือสิทธิพิเศษที่รวมอยู่ใน package
model PackageGift {
  id            String  @id @default(uuid())
  packageId     String  @map("package_id")
  name          String                        // ชื่อของแถม e.g. "ผ้ากันเปื้อน V School"
  qty           Int     @default(1)
  estimatedCost Float?  @map("estimated_cost")
  notes         String?

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@map("package_gifts")
}

// การลงทะเบียน package ของลูกค้า
model PackageEnrollment {
  id           String    @id @default(uuid())
  enrollmentId String    @unique @map("enrollment_id")  // PENR-[YYYY]-[SERIAL]
  packageId    String    @map("package_id")
  customerId   String    @map("customer_id")
  soldById     String?   @map("sold_by_id")
  totalPrice   Float     @map("total_price")
  status       String    @default("ACTIVE")              // ACTIVE|COMPLETED|CANCELLED
  swapUsedAt   DateTime? @map("swap_used_at")            // null = ยังไม่ได้ swap, non-null = ใช้สิทธิ์ไปแล้ว
  enrolledAt   DateTime  @default(now()) @map("enrolled_at")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  package         Package                   @relation(fields: [packageId], references: [id])
  customer        Customer                  @relation(fields: [customerId], references: [id])
  soldBy          Employee?                 @relation("PackageEnrollmentSeller", fields: [soldById], references: [id])
  selectedCourses PackageEnrollmentCourse[]

  @@index([status])
  @@index([customerId])
  @@index([enrolledAt])
  @@map("package_enrollments")
}

// ─────────────────────────────────────────────
// DOMAIN: Stock Audit (Phase 19)
// ─────────────────────────────────────────────

// Append-only audit log ทุกครั้งที่ตัดสต็อก — ใช้ debug + reconcile
model StockDeductionLog {
  id           String   @id @default(uuid())
  scheduleId   String   @map("schedule_id")       // อ้างอิง CourseSchedule.scheduleId (NOT UUID) เพื่อ human-readable
  ingredientId String?  @map("ingredient_id")     // UUID ของ Ingredient (null ถ้าเป็น equipment)
  equipmentId  String?  @map("equipment_id")      // UUID ของ RecipeEquipment (null ถ้าเป็น ingredient)
  lotId        String?  @map("lot_id")              // Phase 20: optional link to IngredientLot.lotId (human-readable, not FK)
  itemName     String   @map("item_name")          // snapshot ชื่อ ณ เวลาตัด (ป้องกัน rename กระทบ history)
  qtyDeducted  Float    @map("qty_deducted")
  unit         String
  studentCount Int      @map("student_count")     // จำนวนนักเรียนที่ใช้คำนวณ
  deductedAt   DateTime @default(now()) @map("deducted_at")

  @@index([scheduleId])
  @@index([ingredientId])
  @@index([deductedAt])
  @@map("stock_deduction_logs")
}

// ─────────────────────────────────────────────
// DOMAIN: Stock Lots (Phase 20)
// ─────────────────────────────────────────────

// รับวัตถุดิบเข้าเป็น lot — รองรับ FEFO/FIFO, expiry tracking, ต้นทุนแยก lot
model IngredientLot {
  id                String           @id @default(uuid())
  lotId             String           @unique @map("lot_id")              // LOT-YYYYMMDD-XXX
  ingredientId      String           @map("ingredient_id")
  purchaseRequestId String?          @map("purchase_request_id")         // link กลับไปที่ PR ที่สั่งซื้อ (optional)
  receivedQty       Float            @map("received_qty")                // จำนวนที่รับเข้า
  remainingQty      Float            @map("remaining_qty")               // จำนวนที่ยังเหลือ (ลดทุกครั้งที่ตัดสต็อก)
  unit              String                                                // ควรตรงกับ Ingredient.unit
  costPerUnit       Decimal?         @map("cost_per_unit") @db.Decimal(10, 2)
  supplier          String?
  expiresAt         DateTime?        @map("expires_at")                  // null = ไม่มีวันหมดอายุ
  receivedAt        DateTime         @default(now()) @map("received_at")
  status            String           @default("ACTIVE")                  // ACTIVE|CONSUMED|EXPIRED|RECALLED
  notes             String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  ingredient      Ingredient       @relation(fields: [ingredientId], references: [id])
  purchaseRequest PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])

  @@index([ingredientId])
  @@index([status])
  @@index([expiresAt])
  @@index([ingredientId, status])
  @@map("ingredient_lots")
}

// คอร์สที่นักเรียนเลือกจริงๆ ใน package enrollment (รองรับ swap group)
model PackageEnrollmentCourse {
  id                  String  @id @default(uuid())
  packageEnrollmentId String  @map("package_enrollment_id")
  productId           String  @map("product_id")
  wasSwapped          Boolean @default(false) @map("was_swapped")  // true = course นี้เป็นผลจากการ swap

  packageEnrollment PackageEnrollment @relation(fields: [packageEnrollmentId], references: [id], onDelete: Cascade)
  product           Product           @relation(fields: [productId], references: [id])

  @@unique([packageEnrollmentId, productId])
  @@map("package_enrollment_courses")
}
